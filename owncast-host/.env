# Cloudflare tunnel token
CLOUDFLARED_TOKEN=

# Host render group ID.
# Get it with:
#   getent group render | cut -d: -f3
RENDER_GID=105

# Source uStreamer MJPEG URL from the Raspberry Pi / TC358743 box
SOURCE_MJPEG_URL=http://hostname:8080/stream

# VAAPI render device inside the container
VAAPI_DEVICE=/dev/dri/renderD128

# Owncast RTMP ingest from inside the Compose network.
# Replace YOUR_OWNCAST_KEY with the stream key from Owncast admin.
OWNCAST_RTMP_URL=rtmp://owncast:1935/live/YOUR_OWNCAST_KEY

# Your source is 1080p25, so GOP 50 gives a 2-second keyframe interval.
GOP_SIZE=50

# Full 1080p settings
VIDEO_BITRATE=5000k
VIDEO_MAXRATE=5000k
VIDEO_BUFSIZE=10000k

# Silent AAC track for RTMP/Owncast compatibility
AUDIO_BITRATE=128k
